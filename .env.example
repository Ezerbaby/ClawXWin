# ClawX Environment Variables

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_PORT=18789

# Development Configuration
VITE_DEV_SERVER_PORT=5173

# Release Configuration (CI/CD)
# Apple Developer Credentials
APPLE_ID=your@email.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# Code Signing Certificate
CSC_LINK=path/to/certificate.p12
CSC_KEY_PASSWORD=certificate_password

# GitHub Token for releases
GH_TOKEN=github_personal_access_token

# 鲁南千易（CWW）后端 API 配置
# 认证、遥测、欢迎页、模型配置等接口的基础地址
# 扫码登录接口: GET {URL}/auth/qr-code, GET {URL}/auth/qr-code/{key}, GET {URL}/auth/me
VITE_CWW_API_BASE_URL=https://lnqy-server.shouhuisoft.com/api/v1
# 版本检查与更新下载服务地址
# 接口: GET {URL}/app/version/check?current_version=X
VITE_CWW_UPDATE_SERVER_URL=https://lnqy-server.shouhuisoft.com/api/v1
# SkillHub 技能商城服务地址
# 搜索: GET {URL}/api/web/skills?q=xxx, 下载: GET {URL}/api/web/skills/{ns}/{slug}/download
VITE_CWW_SKILL_STORE_URL=https://lnqy-server.shouhuisoft.com
# 阿里云 OpenSearch 等集成凭证接口路径（拼接在 API_BASE_URL 之后）
VITE_CWW_CREDENTIALS_PATH=/integrations/credentials
